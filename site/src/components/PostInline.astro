---
import { formatDate, getPostNumber, tagSlug, type Post } from "~/lib/posts";
import { render } from "astro:content";

interface Props {
  post: Post;
  showPermalink?: boolean;
}

const { post, showPermalink = true } = Astro.props;
const { Content } = await render(post);
const n = getPostNumber(post);
const date = formatDate(post.data.pubDate);
---

<article class="mx-auto w-full max-w-prose px-5">
  <header class="mb-10">
    <h2
      class="font-serif text-4xl font-medium leading-tight sm:text-5xl"
      set:html={post.data.title}
    />
    <div
      class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 font-sans text-[11px] uppercase tracking-[0.18em] text-ink-3"
    >
      {post.data.location && (
        <>
          <span>{post.data.location}</span>
          <span aria-hidden="true" class="opacity-50">·</span>
        </>
      )}
      <time datetime={post.data.pubDate.toISOString()}>{date}</time>
      {showPermalink && (
        <>
          <span aria-hidden="true" class="opacity-50">·</span>
          <a
            href={`/${n}`}
            class="inline-flex items-center rounded-full border border-current px-2 py-0.5 leading-none no-underline transition-colors hover:text-ink"
          >
            #{n}
          </a>
        </>
      )}
      {post.data.tags.length > 0 && (
        <>
          <span aria-hidden="true" class="opacity-50">·</span>
          <span class="flex flex-wrap items-center gap-x-2">
            {post.data.tags.map((t) => (
              <a
                href={`/tags/${tagSlug(t)}`}
                class="no-underline transition-colors hover:text-ink"
              >
                #{t}
              </a>
            ))}
          </span>
        </>
      )}
    </div>
  </header>
  <div
    class="prose prose-neutral dark:prose-invert prose-headings:font-serif prose-headings:font-medium prose-a:font-normal font-serif max-w-none"
  >
    <Content />
  </div>
</article>
