---
import { NAV, SITE } from "~/lib/site";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="mx-auto w-full max-w-prose px-5 pt-10 pb-12 sm:pt-14">
  <div class="flex items-baseline justify-between gap-4">
    <a href="/" class="font-serif text-xl tracking-tight no-underline">{SITE.name}</a>
    <ThemeToggle />
  </div>
  <nav class="mt-4 text-sm text-muted-light dark:text-muted-dark">
    {
      NAV.map((item, i) => (
        <span>
          {i > 0 && <span class="mx-1.5 opacity-60">·</span>}
          <a
            href={item.href}
            class="no-underline hover:underline decoration-1 underline-offset-4"
          >
            {item.label}
          </a>
        </span>
      ))
    }
  </nav>
</header>
