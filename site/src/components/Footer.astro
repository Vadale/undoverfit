---
import { SITE } from "~/lib/site";

const year = new Date().getFullYear();
const range =
  year > SITE.startYear ? `${SITE.startYear}–${year}` : `${SITE.startYear}`;
---

<footer class="mx-auto w-full max-w-prose px-5 py-16 text-sm text-ink-3">
  <div class="flex items-center justify-between">
    <span>© {range} {SITE.name}</span>
    <a href="/rss.xml" class="no-underline hover:underline">RSS</a>
  </div>
</footer>
