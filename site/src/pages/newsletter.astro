---
import Layout from "~/layouts/Layout.astro";
---

<Layout
  title="Newsletter"
  description="Get new Undoverfit posts in your inbox."
>
  <section class="mx-auto w-full max-w-prose px-5">
    <h1 class="font-serif text-3xl">Newsletter</h1>
    <p class="mt-3 text-muted-light dark:text-muted-dark">
      New posts in your inbox. No tracking, no ads, unsubscribe anytime.
    </p>

    <div class="mt-10">
      <!-- BEEHIIV_EMBED_PLACEHOLDER -->
      <form
        action="https://example.com/newsletter"
        method="post"
        class="flex flex-col gap-3 sm:flex-row sm:items-center"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 bg-transparent border-b border-rule-light dark:border-rule-dark py-2 outline-none focus:border-accent-navy dark:focus:border-accent-gold"
        />
        <button
          type="submit"
          class="self-start sm:self-auto border border-rule-light dark:border-rule-dark px-4 py-2 text-sm hover:border-accent-navy dark:hover:border-accent-gold transition-colors"
        >
          Subscribe
        </button>
      </form>
      <p class="mt-3 text-xs text-muted-light dark:text-muted-dark">
        Placeholder form. Replace with Beehiiv embed once configured.
      </p>
    </div>
  </section>
</Layout>
