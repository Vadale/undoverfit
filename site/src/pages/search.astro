---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Search" description="Search all posts on Undoverfit.">
  <link
    slot="head"
    rel="stylesheet"
    href="/pagefind/pagefind-ui.css"
    onerror="document.getElementById('search-fallback')?.classList.remove('hidden')"
  />

  <section class="mx-auto w-full max-w-prose px-5">
    <h1 class="font-serif text-3xl">Search</h1>
    <p class="mt-2 text-sm text-ink-3">
      Full-text search across every post.
    </p>

    <div id="search" class="mt-8"></div>
    <p
      id="search-fallback"
      class="mt-8 hidden text-sm text-ink-3"
    >
      Search is built at deploy time. In local dev, run <code>npm run build</code>
      to generate the index, then <code>npm run preview</code>.
    </p>
  </section>
</Layout>
<script is:inline>
  (() => {
    // Cache the load Promise on window so concurrent calls (e.g. View Transition
    // swap mid-load) share the same in-flight request — no double script injection.
    const loadScript = () => {
      if (window.PagefindUI) return Promise.resolve();
      if (window.__pagefindLoadPromise) return window.__pagefindLoadPromise;
      window.__pagefindLoadPromise = new Promise((resolve, reject) => {
        const existing = document.querySelector('script[data-pagefind-ui]');
        if (existing) {
          existing.addEventListener('load', () => resolve(), { once: true });
          existing.addEventListener('error', () => reject(), { once: true });
          return;
        }
        const s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.dataset.pagefindUi = '1';
        s.onload = () => resolve();
        s.onerror = () => reject();
        document.head.appendChild(s);
      });
      return window.__pagefindLoadPromise;
    };

    const mount = async () => {
      const el = document.getElementById('search');
      if (!el || el.dataset.mounted === '1') return;
      try {
        await loadScript();
        // Re-check after await: a parallel mount() may have already claimed the slot,
        // or the user navigated away and the element no longer exists.
        const elNow = document.getElementById('search');
        if (!elNow || elNow.dataset.mounted === '1') return;
        elNow.dataset.mounted = '1';
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          excerptLength: 25,
        });
      } catch (_) {
        document.getElementById('search-fallback')?.classList.remove('hidden');
      }
    };

    mount();
    document.addEventListener('astro:after-swap', () => {
      const el = document.getElementById('search');
      if (el) { el.dataset.mounted = '0'; el.innerHTML = ''; }
      mount();
    });
  })();
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--ink);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--rule);
    --pagefind-ui-tag: transparent;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: theme("fontFamily.sans");
  }
  .pagefind-ui__search-input {
    background: transparent !important;
  }
</style>
