---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Search" description="Search all posts on Undoverfit.">
  <section class="mx-auto w-full max-w-prose px-5">
    <h1 class="font-serif text-3xl">Search</h1>
    <p class="mt-2 text-sm text-muted-light dark:text-muted-dark">
      Full-text search across every post.
    </p>

    <div id="search" class="mt-8"></div>
    <p
      id="search-fallback"
      class="mt-8 hidden text-sm text-muted-light dark:text-muted-dark"
    >
      Search is built at deploy time. In local dev, run <code>npm run build</code>
      to generate the index, then <code>npm run preview</code>.
    </p>
  </section>
</Layout>

<link
  rel="stylesheet"
  href="/pagefind/pagefind-ui.css"
  onerror="document.getElementById('search-fallback')?.classList.remove('hidden')"
/>
<script is:inline>
  (() => {
    const mount = async () => {
      const el = document.getElementById("search");
      if (!el || el.dataset.mounted === "1") return;
      try {
        // @ts-ignore — file is generated by pagefind at build time.
        const mod = await import(/* @vite-ignore */ "/pagefind/pagefind-ui.js");
        el.dataset.mounted = "1";
        new mod.PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          excerptLength: 25,
        });
      } catch (_err) {
        document.getElementById("search-fallback")?.classList.remove("hidden");
      }
    };

    mount();
    document.addEventListener("astro:after-swap", () => {
      const el = document.getElementById("search");
      if (el) {
        el.dataset.mounted = "0";
        el.innerHTML = "";
      }
      mount();
    });
  })();
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: theme("colors.ink.light");
    --pagefind-ui-text: theme("colors.ink.light");
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: theme("colors.rule.light");
    --pagefind-ui-tag: transparent;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: theme("fontFamily.sans");
  }
  html.dark .pagefind-ui {
    --pagefind-ui-primary: theme("colors.ink.dark");
    --pagefind-ui-text: theme("colors.ink.dark");
    --pagefind-ui-border: theme("colors.rule.dark");
  }
  .pagefind-ui__search-input {
    background: transparent !important;
  }
</style>
