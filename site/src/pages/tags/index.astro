---
import Layout from "~/layouts/Layout.astro";
import { getAllTags } from "~/lib/posts";

const tags = await getAllTags();
---

<Layout title="Tags" description="All tags used on Undoverfit, with post counts.">
  <section class="mx-auto w-full max-w-prose px-5">
    <h1 class="font-serif text-3xl">Tags</h1>
    <p class="mt-2 text-sm text-ink-3">
      A flat list. Each tag links to all the posts using it.
    </p>

    {tags.length === 0 ? (
      <p class="mt-10 text-ink-3">No tags yet.</p>
    ) : (
      <ul class="mt-10 divide-y divide-rule">
        {tags.map((t) => (
          <li class="py-3">
            <a
              href={`/tags/${t.slug}`}
              class="flex items-baseline justify-between gap-4 no-underline hover:underline decoration-1 underline-offset-4"
            >
              <span class="font-serif">{t.tag}</span>
              <span class="text-sm text-ink-3 tabular-nums">
                {t.count} post{t.count === 1 ? "" : "s"}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
