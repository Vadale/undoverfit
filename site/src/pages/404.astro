---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Not found" description="This page does not exist.">
  <section class="mx-auto w-full max-w-prose px-5 text-center">
    <h1 class="font-serif text-3xl">Not found</h1>
    <p class="mt-4 text-ink-3">
      The page you are looking for does not exist, or has been moved.
    </p>
    <p class="mt-8">
      <a href="/" class="no-underline hover:underline">Back to the homepage</a>
    </p>
  </section>
</Layout>
