---
import Layout from "~/layouts/Layout.astro";
import Comments from "~/components/Comments.astro";
import {
  formatDate,
  getAdjacent,
  getPostNumber,
  getPublishedPosts,
  tagSlug,
  type Post,
} from "~/lib/posts";
import { SITE } from "~/lib/site";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content } = await render(post);
const n = getPostNumber(post);
const date = formatDate(post.data.pubDate);
const { prev, next } = await getAdjacent(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
  image={`/og/${n}.png`}
  pubDate={post.data.pubDate}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      "url": `${SITE.url}/${n}`,
      "image": `${SITE.url}/og/${n}.png`,
      "author": { "@type": "Person", "name": SITE.author, "url": `${SITE.url}/about` },
      "publisher": { "@type": "Person", "name": SITE.author },
      "mainEntityOfPage": `${SITE.url}/${n}`,
      "inLanguage": SITE.language,
      "keywords": post.data.tags.join(", ")
    })}
  />
  <meta slot="head" property="article:author" content={SITE.author} />
  {post.data.tags.map((t) => (
    <meta slot="head" property="article:tag" content={t} />
  ))}

  <article class="mx-auto w-full max-w-prose px-5" data-pagefind-body>
    <header class="mb-8">
      <h1 class="font-serif text-3xl leading-tight sm:text-4xl">
        {post.data.title}
      </h1>
      <p class="mt-3 text-sm text-muted-light dark:text-muted-dark">
        {post.data.location && <span>{post.data.location} · </span>}
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span> · page {n}</span>
      </p>
    </header>

    <div
      class="prose prose-neutral dark:prose-invert prose-headings:font-serif prose-headings:font-medium prose-a:font-normal max-w-none"
    >
      <Content />
    </div>

    {post.data.tags.length > 0 && (
      <p class="mt-10 text-sm text-muted-light dark:text-muted-dark">
        Tagged:{" "}
        {post.data.tags.map((t, i) => (
          <>
            {i > 0 && <span>, </span>}
            <a href={`/tags/${tagSlug(t)}`} class="no-underline hover:underline">{t}</a>
          </>
        ))}
      </p>
    )}

    <nav
      class="mt-16 flex items-center justify-between text-sm text-muted-light dark:text-muted-dark"
      aria-label="Post navigation"
    >
      {prev ? (
        <a href={`/${getPostNumber(prev)}`} class="no-underline hover:underline">
          ‹ page {getPostNumber(prev)}
        </a>
      ) : (
        <span></span>
      )}
      {next ? (
        <a href={`/${getPostNumber(next)}`} class="no-underline hover:underline">
          page {getPostNumber(next)} ›
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </article>

  {post.data.comments && <Comments />}
</Layout>
