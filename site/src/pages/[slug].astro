---
import Layout from "~/layouts/Layout.astro";
import Comments from "~/components/Comments.astro";
import {
  formatDate,
  getAdjacent,
  getPostNumber,
  getPublishedPosts,
  plainTitle,
  tagSlug,
  type Post,
} from "~/lib/posts";
import { SITE } from "~/lib/site";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content } = await render(post);
const n = getPostNumber(post);
const date = formatDate(post.data.pubDate);
const { prev, next } = await getAdjacent(post);
---

<Layout
  title={plainTitle(post.data.title)}
  description={post.data.description}
  type="article"
  image={`/og/${n}.png`}
  pubDate={post.data.pubDate}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": plainTitle(post.data.title),
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      "url": `${SITE.url}/${n}`,
      "image": `${SITE.url}/og/${n}.png`,
      "author": { "@type": "Person", "name": SITE.author, "url": `${SITE.url}/about` },
      "publisher": { "@type": "Person", "name": SITE.author },
      "mainEntityOfPage": `${SITE.url}/${n}`,
      "inLanguage": SITE.language,
      "keywords": post.data.tags.join(", ")
    })}
  />
  <meta slot="head" property="article:author" content={SITE.author} />
  {post.data.tags.map((t) => (
    <meta slot="head" property="article:tag" content={t} />
  ))}

  <article class="mx-auto w-full max-w-prose px-5" data-pagefind-body>
    <header class="mb-12">
      <h1
        class="font-serif text-4xl leading-tight sm:text-5xl"
        set:html={post.data.title}
      />
      <div
        class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 font-sans text-[11px] uppercase tracking-[0.18em] text-ink-3"
      >
        {post.data.location && (
          <>
            <span>{post.data.location}</span>
            <span aria-hidden="true" class="opacity-50">·</span>
          </>
        )}
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span aria-hidden="true" class="opacity-50">·</span>
        <span class="inline-flex items-center rounded-full border border-current px-2 py-0.5 leading-none">
          #{n}
        </span>
        {post.data.tags.length > 0 && (
          <>
            <span aria-hidden="true" class="opacity-50">·</span>
            <span class="flex flex-wrap items-center gap-x-2">
              {post.data.tags.map((t) => (
                <a
                  href={`/tags/${tagSlug(t)}`}
                  class="no-underline transition-colors hover:text-ink"
                >
                  #{t}
                </a>
              ))}
            </span>
          </>
        )}
      </div>
    </header>

    <div
      class="prose prose-neutral dark:prose-invert prose-headings:font-serif prose-headings:font-medium prose-a:font-normal font-serif max-w-none"
    >
      <Content />
    </div>

    <nav
      class="mt-20 flex items-center justify-between font-sans text-[11px] uppercase tracking-[0.18em] text-ink-3"
      aria-label="Post navigation"
    >
      {prev ? (
        <a href={`/${getPostNumber(prev)}`} class="no-underline hover:underline">
          ‹ page {getPostNumber(prev)}
        </a>
      ) : (
        <span></span>
      )}
      {next ? (
        <a href={`/${getPostNumber(next)}`} class="no-underline hover:underline">
          page {getPostNumber(next)} ›
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </article>

  {post.data.comments && <Comments />}
</Layout>
