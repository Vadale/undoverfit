---
import "~/styles/global.css";
import { SITE } from "~/lib/site";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import Sounds from "~/components/Sounds.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  canonical?: string;
  pubDate?: Date;
}

const {
  title,
  description = SITE.description,
  image,
  type = "website",
  canonical,
  pubDate,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const url = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = image
  ? new URL(image, SITE.url).toString()
  : new URL("/og-default.png", SITE.url).toString();
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title ?? SITE.name} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? SITE.name} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#f4f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1a26" media="(prefers-color-scheme: dark)" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": SITE.name,
      "url": SITE.url,
      "description": SITE.description,
      "inLanguage": SITE.language,
      "author": {
        "@type": "Person",
        "name": SITE.author,
        "url": `${SITE.url}/about`
      }
    })} />

    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=Plus+Jakarta+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <script is:inline>
      // Apply theme before paint to avoid flash.
      // Default is light. Dark mode only if the user explicitly toggled it
      // (stored = "dark"). System dark-mode is intentionally ignored.
      (() => {
        const stored = localStorage.getItem("theme");
        const isDark = stored === "dark";
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>
  <body>
    <div id="bg-wrap" aria-hidden="true" transition:persist></div>
    <Header />
    <main class="fade-in">
      <slot />
    </main>
    <Footer />
    <Sounds />

    <script is:inline>
      (function () {
        function buildHalftoneSvg(opts) {
          const width = (opts && opts.width) || 1600;
          const height = (opts && opts.height) || 1100;
          const cell = (opts && opts.cell) || 12;
          let s = (opts && opts.seed) || 23;
          const rnd = () => {
            s = (s * 9301 + 49297) % 233280;
            return s / 233280;
          };
          const oct = [];
          let a = 1, f = 0.0055;
          for (let i = 0; i < 4; i++) {
            oct.push({
              a,
              fx: f * (0.7 + rnd() * 0.6),
              fy: f * (0.7 + rnd() * 0.6) * (rnd() > 0.5 ? 1 : -1),
              ph: rnd() * Math.PI * 2,
            });
            a *= 0.55;
            f *= 2.05;
          }
          const noise = (x, y) => {
            let v = 0;
            for (const o of oct) v += o.a * Math.sin(x * o.fx + y * o.fy + o.ph);
            return (v / 1.8 + 1) / 2;
          };
          const maxR = cell * 0.55;
          const cols = Math.ceil(width / cell) + 2;
          const rows = Math.ceil(height / cell) + 2;
          let dots = "";
          for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
              const x = c * cell;
              const y = r * cell;
              let n = Math.pow(noise(x, y), 1.7);
              const radius = 0.35 + n * maxR;
              if (radius < 0.4) continue;
              dots += '<circle cx="' + x.toFixed(1) + '" cy="' + y.toFixed(1) + '" r="' + radius.toFixed(2) + '"/>';
            }
          }
          return '<svg class="halftone" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + width + ' ' + height + '" preserveAspectRatio="xMidYMid slice"><g fill="currentColor">' + dots + '</g></svg>';
        }

        function mountHalftone(opts) {
          const node = document.getElementById("bg-wrap");
          if (!node || node.dataset.mounted === "1") return;
          node.dataset.mounted = "1";
          const intensity = (opts && opts.intensity) || 1;
          node.innerHTML = buildHalftoneSvg(opts) + '<div class="vignette"></div>';
          const svg = node.querySelector("svg.halftone");
          if (svg) svg.style.opacity = (0.06 * intensity).toFixed(3);
        }

        function getHalftoneOpts() {
          if (window.innerWidth < 768) {
            return { width: 900, height: 1400, cell: 10 };
          }
          return { width: 1600, height: 1100, cell: 12 };
        }

        mountHalftone(getHalftoneOpts());
        document.addEventListener("astro:after-swap", () => mountHalftone(getHalftoneOpts()));
      })();
    </script>
  </body>
</html>
